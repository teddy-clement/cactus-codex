# ── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Authentification JWT ────────────────────────────────────────
# Secret indépendant de la clé ingest — NE PAS mutualiser
AUTH_SECRET=votre_secret_jwt_fort_min_32_chars

# ── OTP Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@cactus-codex.com
# Activer le double facteur OTP (true/false)
AUTH_REQUIRE_OTP=false

# ── Sécurité : clé d'ingestion des signaux CoTrain ──────────────
# Variable SERVEUR uniquement — NE JAMAIS mettre NEXT_PUBLIC_ ici
# Doit correspondre à CODEX_INGEST_KEY dans l'env de CoTrain
CACTUS_CODEX_INGEST_KEY=votre_secret_ingest_fort_min_32_chars

# ── Webhook vers CoTrain (push broadcasts) ──────────────────────
COTRAIN_WEBHOOK_URL=https://cotrain-vbeta.vercel.app/api/codex/broadcast
COTRAIN_WEBHOOK_SECRET=votre_secret_webhook_fort_min_32_chars

# ── CORS : origines autorisées sur /api/public/* ────────────────
# Séparées par des virgules si plusieurs domaines
ALLOWED_ORIGINS=https://cotrain-vbeta.vercel.app

# ── URL publique de ce Codex ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cactus-codex.com
