# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Auth ────────────────────────────────────────────
# Secret JWT pour les sessions (générer avec: openssl rand -base64 32)
AUTH_SECRET=your_super_secret_jwt_key_here

# ─── Email (Resend) ──────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=t.clement@cactus-codex.com

# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cactus-codex.com
NODE_ENV=production
AUTH_REQUIRE_OTP=false
EMAIL_FROM=no-reply@cactus-codex.com
